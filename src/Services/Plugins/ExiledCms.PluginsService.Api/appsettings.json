{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Service": {
    "Name": "plugins-service",
    "DisplayName": "Plugins Service",
    "Version": "1.0.0",
    "BaseUrl": "http://plugins-service:8080",
    "OpenApiJsonPath": "/swagger/v1/swagger.json",
    "SwaggerUiPath": "/swagger"
  },
  "PlatformCore": {
    "BaseUrl": "http://platform-core:8080",
    "AutoRegister": true,
    "RetryIntervalSeconds": 30
  },
  "AllowedHosts": "*"
}
